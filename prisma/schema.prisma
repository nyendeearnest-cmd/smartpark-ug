generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ATTENDANT
}

model User {
  id        String   @id @default(cuid())
  fullName  String
  email     String   @unique
  password  String
  role      UserRole @default(ATTENDANT)
  parkingRecords ParkingRecord[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model VehicleType {
  id                 String   @id @default(cuid())
  name               String   @unique
 firstHourRate      Decimal @db.Decimal(10,2)
additionalHourRate Decimal @db.Decimal(10,2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  vehicles           Vehicle[]
}
model Vehicle {
  id            String      @id @default(cuid())
  numberPlate   String      @unique
  driverName    String
  driverPhone   String

  vehicleTypeId String
  vehicleType   VehicleType @relation(fields: [vehicleTypeId], references: [id])

parkingRecords ParkingRecord[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}
enum SlotStatus {
  AVAILABLE
  OCCUPIED
}

enum SlotCondition {
  ACTIVE
  RESERVED
  MAINTENANCE
}

model ParkingSlot {
  id          String        @id @default(cuid())
  slotNumber  String        @unique
 zone ParkingZone

  status      SlotStatus    @default(AVAILABLE)
  condition   SlotCondition @default(ACTIVE)

parkingRecords ParkingRecord[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}
enum ParkingStatus {
  ACTIVE
  COMPLETED
}
enum ParkingZone {
  A
  B
  C
}

model ParkingRecord {
  id               String         @id @default(cuid())

  vehicleId        String
  vehicle          Vehicle        @relation(fields: [vehicleId], references: [id])

  parkingSlotId    String
  parkingSlot      ParkingSlot    @relation(fields: [parkingSlotId], references: [id])

checkedInById    String?
checkedInBy      User? @relation(fields: [checkedInById], references: [id])

  checkInTime      DateTime       @default(now())
  checkOutTime     DateTime?

  durationMinutes  Int?
  amountCharged    Decimal?

  status           ParkingStatus  @default(ACTIVE)

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}
model SystemSetting {
  id            String   @id @default(cuid())

  companyName   String
  phone         String?
  email         String?
  address       String?
  logo          String?

  pricePerHour  Float    @default(1000)
  gracePeriod   Int      @default(15)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
model AuditLog {
  id        String   @id @default(cuid())
  action    String
  user      String
  createdAt DateTime @default(now())
}